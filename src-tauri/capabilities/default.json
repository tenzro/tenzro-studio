{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for the Tenzro Studio main window: every Tauri-plugin permission the app uses, scoped to the only window (`main`).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:event:default",
    "core:app:default",
    "core:path:default",
    "core:menu:default",
    "shell:default",
    "shell:allow-open",
    "store:default",
    "dialog:default",
    "deep-link:default",
    "global-shortcut:default",
    "window-state:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "updater:default"
  ]
}
