{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Tenzro Studio",
  "version": "0.1.0",
  "identifier": "com.tenzro.studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis", "deb", "rpm", "appimage"],
    "externalBin": [
      "binaries/llama-server"
    ],
    "resources": [
      "templates/*.jinja"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Run, serve, and contribute AI to the Tenzro Network",
    "longDescription": "Tenzro Studio runs an embedded Tenzro node so any user can download AI models from the Tenzro registry, run them locally with GPU acceleration, serve them to the network as a provider, and contribute compute to decentralized training runs — all from one bundled installer with no manual setup.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist",
      "signingIdentity": "Developer ID Application: Ahmed Hilal Agil (R5FXGKNFBP)",
      "hardenedRuntime": true,
      "infoPlist": "Info.plist"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "perMachine"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Tenzro Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "closable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 19, "y": 24 }
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["tenzro-studio"]
      }
    },
    "updater": {
      "active": true,
      "pubkey": "PUT_TAURI_UPDATER_PUBKEY_HERE",
      "endpoints": [
        "https://tenzro.com/studio/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
