# Node / Vite
node_modules
dist
dist-ssr
.vite

# Tauri / Rust
src-tauri/target
src-tauri/Cargo.lock
src-tauri/gen

# OS
.DS_Store
Thumbs.db

# Editor
.vscode
.idea
*.swp

# Claude Code local settings / session data
.claude

# Local secrets / env
.env
.env.local
.env.*.local

# Signing / updater keys + provisioning profiles — NEVER commit. The Tauri
# updater private key lives outside the repo (~/.tauri); these patterns are a
# defensive guard against accidental in-tree commits.
*.key
!**/jinja/**/*.key
*.pem
*.p12
*.provisionprofile
src-tauri/embedded.provisionprofile

# Local cargo patches (per CONTRIBUTING.md, these stay machine-local)
.cargo/config.toml

# llama-server sidecar binaries — produced by the build script, not
# checked in (each is ~17 MB and platform-specific). See
# scripts/build-sidecar.sh.
src-tauri/binaries/llama-server-*
